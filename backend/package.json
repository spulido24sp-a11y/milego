{
  "name": "milego-api",
  "version": "7.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.cjs",
    "seed": "knex seed:run --knexfile knexfile.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.18",
    "knex": "^3.1",
    "pg": "^8.11",
    "jsonwebtoken": "^9.0",
    "argon2": "^0.31",
    "zod": "^3.22",
    "helmet": "^7.1",
    "cors": "^2.8",
    "express-rate-limit": "^7.1",
    "pino": "^8.17",
    "pino-pretty": "^10.3",
    "swagger-jsdoc": "^6.2",
    "swagger-ui-express": "^5.0",
    "uuid": "^9.0",
    "dotenv": "^16.3",
    "yaml": "^2.3"
  },
  "devDependencies": {
    "vitest": "^1.2",
    "nodemon": "^3.0"
  }
}